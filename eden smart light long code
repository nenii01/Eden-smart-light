"""
Smart Bulb System with Web-Based Guest Access Control
Allows admins to grant temporary, room-specific control to guests via browser.
"""

from enum import Enum
from datetime import datetime, timedelta
from typing import Optional, Tuple, Dict, List
import json
import uuid
from abc import ABC, abstractmethod


class ColorMode(Enum):
    """Supported color modes for the smart bulb."""
    WHITE = "white"
    RGB = "rgb"


class RoomType(Enum):
    """Types of rooms in an apartment."""
    LIVING_ROOM = "living_room"
    BEDROOM = "bedroom"
    KITCHEN = "kitchen"
    BATHROOM = "bathroom"
    OFFICE = "office"


class AccessLevel(Enum):
    """Access levels for users."""
    ADMIN = "admin"
    GUEST = "guest"
    RESTRICTED = "restricted"


class SmartBulb:
    """Individual smart bulb with control features."""
    
    def __init__(self, bulb_id: str, name: str, max_brightness: int = 100):
        self.bulb_id = bulb_id
        self.name = name
        self.max_brightness = max_brightness
        
        self._is_on = False
        self._brightness = 100
        self._color_mode = ColorMode.WHITE
        self._color_temperature = 6500
        self._rgb_color = (255, 255, 255)
        self._last_update = datetime.now()
    
    @property
    def is_on(self) -> bool:
        return self._is_on
    
    @property
    def brightness(self) -> int:
        return self._brightness
    
    @property
    def color_mode(self) -> ColorMode:
        return self._color_mode
    
    @property
    def rgb_color(self) -> Tuple[int, int, int]:
        return self._rgb_color
    
    @property
    def color_temperature(self) -> int:
        return self._color_temperature
    
    def turn_on(self) -> None:
        self._is_on = True
        self._last_update = datetime.now()
    
    def turn_off(self) -> None:
        self._is_on = False
        self._last_update = datetime.now()
    
    def set_brightness(self, level: int) -> None:
        if not 0 <= level <= self.max_brightness:
            raise ValueError(f"Brightness must be between 0 and {self.max_brightness}")
        
        self._brightness = level
        if level > 0 and not self._is_on:
            self.turn_on()
        elif level == 0:
            self.turn_off()
        
        self._last_update = datetime.now()
    
    def set_rgb_color(self, red: int, green: int, blue: int) -> None:
        for component in [red, green, blue]:
            if not 0 <= component <= 255:
                raise ValueError("RGB components must be between 0 and 255")
        
        self._color_mode = ColorMode.RGB
        self._rgb_color = (red, green, blue)
        if not self._is_on:
            self.turn_on()
        
        self._last_update = datetime.now()
    
    def set_color_temperature(self, kelvin: int) -> None:
        if not 2700 <= kelvin <= 6500:
            raise ValueError("Color temperature must be between 2700K and 6500K")
        
        self._color_mode = ColorMode.WHITE
        self._color_temperature = kelvin
        if not self._is_on:
            self.turn_on()
        
        self._last_update = datetime.now()
    
    def get_status(self) -> dict:
        return {
            "id": self.bulb_id,
            "name": self.name,
            "is_on": self._is_on,
            "brightness": self._brightness,
            "color_mode": self._color_mode.value,
            "rgb_color": self._rgb_color,
            "color_temperature": self._color_temperature,
            "last_update": self._last_update.isoformat()
        }


class Room:
    """A room containing multiple smart bulbs."""
    
    def __init__(self, room_id: str, name: str, room_type: RoomType):
        self.room_id = room_id
        self.name = name
        self.room_type = room_type
        self.bulbs: Dict[str, SmartBulb] = {}
    
    def add_bulb(self, bulb: SmartBulb) -> None:
        self.bulbs[bulb.bulb_id] = bulb
    
    def get_bulb(self, bulb_id: str) -> Optional[SmartBulb]:
        return self.bulbs.get(bulb_id)
    
    def turn_all_on(self) -> None:
        for bulb in self.bulbs.values():
            bulb.turn_on()
    
    def turn_all_off(self) -> None:
        for bulb in self.bulbs.values():
            bulb.turn_off()
    
    def set_all_brightness(self, level: int) -> None:
        for bulb in self.bulbs.values():
            bulb.set_brightness(level)
    
    def get_status(self) -> dict:
        return {
            "room_id": self.room_id,
            "name": self.name,
            "room_type": self.room_type.value,
            "bulbs": {bulb_id: bulb.get_status() for bulb_id, bulb in self.bulbs.items()},
            "bulb_count": len(self.bulbs)
        }


class User:
    """User account with access levels and permissions."""
    
    def __init__(self, user_id: str, name: str, access_level: AccessLevel, email: str = ""):
        self.user_id = user_id
        self.name = name
        self.access_level = access_level
        self.email = email
        self.created_at = datetime.now()
    
    def is_admin(self) -> bool:
        return self.access_level == AccessLevel.ADMIN
    
    def is_guest(self) -> bool:
        return self.access_level == AccessLevel.GUEST


class GuestPass:
    """Temporary guest pass with time-limited, room-specific access."""
    
    def __init__(self, guest_user: User, rooms: List[Room], duration_hours: int = 24):
        self.pass_id = str(uuid.uuid4())
        self.guest_user = guest_user
        self.rooms = {room.room_id: room for room in rooms}
        self.created_at = datetime.now()
        self.expires_at = self.created_at + timedelta(hours=duration_hours)
        self.is_active = True
        self.access_token = str(uuid.uuid4())  # For browser-based access
        self.control_settings = {
            "can_turn_on_off": True,
            "can_adjust_brightness": True,
            "can_change_color": True,
            "can_set_temperature": True
        }
    
    def is_valid(self) -> bool:
        """Check if the guest pass is still valid."""
        return self.is_active and datetime.now() < self.expires_at
    
    def has_room_access(self, room_id: str) -> bool:
        """Check if guest has access to a specific room."""
        return self.is_valid() and room_id in self.rooms
    
    def revoke(self) -> None:
        """Revoke guest access immediately."""
        self.is_active = False
    
    def get_access_url(self, host: str = "localhost:5000") -> str:
        """Generate a shareable web URL for guest access."""
        return f"http://{host}/guest-control/{self.access_token}"
    
    def get_expiry_info(self) -> dict:
        """Get information about when this pass expires."""
        time_remaining = self.expires_at - datetime.now()
        hours_remaining = int(time_remaining.total_seconds() / 3600)
        minutes_remaining = int((time_remaining.total_seconds() % 3600) / 60)
        
        return {
            "pass_id": self.pass_id,
            "expires_at": self.expires_at.isoformat(),
            "hours_remaining": hours_remaining,
            "minutes_remaining": minutes_remaining,
            "is_valid": self.is_valid()
        }
    
    def to_json(self) -> dict:
        return {
            "pass_id": self.pass_id,
            "guest_name": self.guest_user.name,
            "rooms": list(self.rooms.keys()),
            "created_at": self.created_at.isoformat(),
            "expires_at": self.expires_at.isoformat(),
            "is_active": self.is_active,
            "access_url": self.get_access_url(),
            "control_settings": self.control_settings
        }


class SmartHomeSystem:
    """Central system managing rooms, bulbs, users, and guest access."""
    
    def __init__(self):
        self.rooms: Dict[str, Room] = {}
        self.users: Dict[str, User] = {}
        self.guest_passes: Dict[str, GuestPass] = {}
        self.active_sessions: Dict[str, GuestPass] = {}  # Token -> GuestPass mapping
    
    # ==================== ADMIN FUNCTIONS ====================
    
    def add_room(self, room: Room) -> None:
        """Admin: Add a new room."""
        self.rooms[room.room_id] = room
        print(f"✅ Room added: {room.name}")
    
    def add_user(self, user: User) -> None:
        """Admin: Add a new user."""
        self.users[user.user_id] = user
        print(f"✅ User added: {user.name} ({user.access_level.value})")
    
    def create_guest_pass(
        self,
        admin_user: User,
        guest_name: str,
        room_ids: List[str],
        duration_hours: int = 24,
        guest_email: str = ""
    ) -> GuestPass:
        """
        Admin: Create a temporary guest pass for a visitor.
        
        Args:
            admin_user: The admin creating the pass
            guest_name: Name of the visiting guest
            room_ids: List of room IDs guest can control (e.g., ['room_living', 'room_bedroom'])
            duration_hours: How many hours the pass is valid for
            guest_email: Optional email to send invite to
        
        Returns:
            GuestPass object with access details
        """
        if not admin_user.is_admin():
            raise PermissionError("Only admins can create guest passes")
        
        # Create guest user
        guest_id = f"guest_{uuid.uuid4().hex[:8]}"
        guest_user = User(guest_id, guest_name, AccessLevel.GUEST, guest_email)
        self.users[guest_id] = guest_user
        
        # Get requested rooms
        rooms = [self.rooms[rid] for rid in room_ids if rid in self.rooms]
        
        if not rooms:
            raise ValueError("No valid rooms specified")
        
        # Create pass
        guest_pass = GuestPass(guest_user, rooms, duration_hours)
        self.guest_passes[guest_pass.pass_id] = guest_pass
        self.active_sessions[guest_pass.access_token] = guest_pass
        
        print(f"✅ Guest pass created for {guest_name}")
        print(f"   Rooms: {', '.join([r.name for r in rooms])}")
        print(f"   Valid for: {duration_hours} hours")
        print(f"   Access URL: {guest_pass.get_access_url()}")
        
        return guest_pass
    
    def revoke_guest_pass(self, admin_user: User, pass_id: str) -> None:
        """Admin: Revoke a guest pass immediately."""
        if not admin_user.is_admin():
            raise PermissionError("Only admins can revoke guest passes")
        
        if pass_id in self.guest_passes:
            self.guest_passes[pass_id].revoke()
            print(f"🚫 Guest pass {pass_id} has been revoked")
    
    def list_active_guest_passes(self, admin_user: User) -> List[dict]:
        """Admin: List all active guest passes."""
        if not admin_user.is_admin():
            raise PermissionError("Only admins can view guest passes")
        
        active = [gp.to_json() for gp in self.guest_passes.values() if gp.is_valid()]
        return active
    
    # ==================== GUEST FUNCTIONS ====================
    
    def authenticate_guest(self, access_token: str) -> Optional[GuestPass]:
        """Authenticate a guest using their access token."""
        guest_pass = self.active_sessions.get(access_token)
        if guest_pass and guest_pass.is_valid():
            return guest_pass
        return None
    
    def get_guest_accessible_rooms(self, guest_pass: GuestPass) -> Dict[str, dict]:
        """Get all rooms accessible to a guest."""
        if not guest_pass.is_valid():
            raise PermissionError("Guest pass has expired or been revoked")
        
        return {room_id: room.get_status() for room_id, room in guest_pass.rooms.items()}
    
    def guest_control_bulb(
        self,
        guest_pass: GuestPass,
        room_id: str,
        bulb_id: str,
        action: str,
        **kwargs
    ) -> dict:
        """
        Guest: Perform an action on a bulb in an accessible room.
        
        Actions: 'turn_on', 'turn_off', 'set_brightness', 'set_color_temperature', 'set_rgb_color'
        """
        if not guest_pass.is_valid():
            raise PermissionError("Guest pass has expired")
        
        if not guest_pass.has_room_access(room_id):
            raise PermissionError(f"Guest does not have access to room {room_id}")
        
        room = guest_pass.rooms.get(room_id)
        bulb = room.get_bulb(bulb_id)
        
        if not bulb:
            raise ValueError(f"Bulb {bulb_id} not found in room")
        
        # Apply action based on control settings
        settings = guest_pass.control_settings
        
        if action == "turn_on" and settings["can_turn_on_off"]:
            bulb.turn_on()
        elif action == "turn_off" and settings["can_turn_on_off"]:
            bulb.turn_off()
        elif action == "set_brightness" and settings["can_adjust_brightness"]:
            bulb.set_brightness(kwargs.get("level", 50))
        elif action == "set_color_temperature" and settings["can_set_temperature"]:
            bulb.set_color_temperature(kwargs.get("kelvin", 6500))
        elif action == "set_rgb_color" and settings["can_change_color"]:
            bulb.set_rgb_color(
                kwargs.get("red", 255),
                kwargs.get("green", 255),
                kwargs.get("blue", 255)
            )
        else:
            raise PermissionError(f"Guest is not allowed to perform action: {action}")
        
        print(f"✓ Guest controlled {bulb.name}: {action}")
        return bulb.get_status()
    
    def guest_control_room(
        self,
        guest_pass: GuestPass,
        room_id: str,
        action: str,
        **kwargs
    ) -> dict:
        """
        Guest: Perform a room-level action (all bulbs in room).
        
        Actions: 'turn_all_on', 'turn_all_off', 'set_all_brightness'
        """
        if not guest_pass.is_valid():
            raise PermissionError("Guest pass has expired")
        
        if not guest_pass.has_room_access(room_id):
            raise PermissionError(f"Guest does not have access to room {room_id}")
        
        room = guest_pass.rooms.get(room_id)
        
        if action == "turn_all_on":
            room.turn_all_on()
        elif action == "turn_all_off":
            room.turn_all_off()
        elif action == "set_all_brightness":
            room.set_all_brightness(kwargs.get("level", 50))
        else:
            raise ValueError(f"Unknown room action: {action}")
        
        print(f"✓ Guest controlled room {room.name}: {action}")
        return room.get_status()
    
    # ==================== SYSTEM INFO ====================
    
    def get_home_status(self) -> dict:
        """Get overall status of all rooms and bulbs."""
        return {
            "rooms": {room_id: room.get_status() for room_id, room in self.rooms.items()},
            "total_rooms": len(self.rooms),
            "total_bulbs": sum(len(room.bulbs) for room in self.rooms.values()),
            "active_guest_passes": len([gp for gp in self.guest_passes.values() if gp.is_valid()])
        }


