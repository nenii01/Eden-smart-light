    bedroom.add_bulb(SmartBulb("bulb_bed_2", "Bedside Light"))
    home.add_room(bedroom)
    
    kitchen = Room("room_kitchen", "Kitchen", RoomType.KITCHEN)
    kitchen.add_bulb(SmartBulb("bulb_k_1", "Overhead Light"))
    home.add_room(kitchen)
    
    print("\n" + "="*60)
    print("ADMIN: Creating guest pass for visiting friend")
    print("="*60)
    
    # Admin creates a guest pass for specific rooms
    guest_pass = home.create_guest_pass(
        admin_user=admin,
        guest_name="Sarah (Guest)",
        room_ids=["room_living", "room_bed"],
        duration_hours=8,
        guest_email="sarah@example.com"
    )
    
    print("\n" + "="*60)
    print("GUEST: Accessing controls via web browser")
    print("="*60)
    
    # Guest authenticates with token (simulating web login)
    print(f"\n🔑 Guest access token: {guest_pass.access_token}")
    authenticated_pass = home.authenticate_guest(guest_pass.access_token)
    
    if authenticated_pass:
        print("✅ Guest authenticated successfully!")
        
        # Guest views available rooms
        print("\n📍 Guest can control these rooms:")
        accessible_rooms = home.get_guest_accessible_rooms(authenticated_pass)
        for room_id, room_status in accessible_rooms.items():
            print(f"   - {room_status['name']} ({len(room_status['bulbs'])} bulbs)")
        
        # Guest controls living room lights
        print("\n💡 Guest actions in Living Room:")
        
